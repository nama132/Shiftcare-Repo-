# Copy this file to `.env` and fill in real values. Never commit `.env`.

# SMS provider: "vonage" (default) or "twilio"
SMS_PROVIDER=vonage

# Vonage — get these from dashboard.nexmo.com → top of the page
VONAGE_API_KEY=your_api_key
VONAGE_API_SECRET=your_api_secret
VONAGE_FROM=+1XXXXXXXXXX

# Twilio — get these from console.twilio.com (switch SMS_PROVIDER=twilio to use)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_FROM=+1XXXXXXXXXX

# Telnyx — get these from dashboard.telnyx.com (switch SMS_PROVIDER=telnyx to use)
TELNYX_API_KEY=your_telnyx_api_key
TELNYX_FROM=+1XXXXXXXXXX

ANTHROPIC_API_KEY=sk-ant-...

# Owner phone — receives the post-coverage summary SMS
OWNER_PHONE=+1XXXXXXXXXX

# Admin panel password
ADMIN_PASSWORD=shiftcare2026

# Flask secret key (change this in production)
SECRET_KEY=change-me-in-production

# Family portal — set to your public URL so the link texted to families works
# Locally: http://localhost:5000  |  Production: https://your-app.up.railway.app
BASE_URL=http://localhost:5000

# Telnyx demo phones (used by seed.py)
TELNYX_NUMBER_1=+1XXXXXXXXXX   # Maria — texts IN to cancel
TELNYX_NUMBER_2=+1XXXXXXXXXX   # Priya — receives coverage request, replies YES

# Set to 1 to print SMS to terminal instead of sending (no credits used)
DRY_RUN_SMS=1
